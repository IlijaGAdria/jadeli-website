{
  "name": "@case-couture/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "db:generate": "dotenv -e ../../backend/.env -- prisma generate",
    "db:migrate": "dotenv -e ../../backend/.env -- prisma migrate dev",
    "db:push": "dotenv -e ../../backend/.env -- prisma db push",
    "db:studio": "dotenv -e ../../backend/.env -- prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.2",
    "prisma": "^5.20.0",
    "typescript": "^5.6.0"
  }
}
